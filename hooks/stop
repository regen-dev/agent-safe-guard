#!/usr/bin/env bash
# stop: Handle stop events with duration tracking
set -euo pipefail

source "${BASH_SOURCE[0]%/*}/lib/common.sh"

LOG_FILE="$HOME/.claude/session-log.txt"
_sg_read_input || exit 0

STOP_HOOK_ACTIVE=$(printf '%s' "$SG_INPUT" | jq -r '.stop_hook_active // false' 2>/dev/null)
[[ "$STOP_HOOK_ACTIVE" == "true" ]] && exit 0

IFS=$'\x1f' read -r REASON TOOL_NAME SESSION_ID < <(
    printf '%s' "$SG_INPUT" | jq -r '[.reason // "unknown", .tool_name // "", .session_id // ""] | join("\u001f")' 2>/dev/null
) || exit 0

SESSION_ID=$(_sg_sanitize_id "$SESSION_ID")

TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')

DURATION="unknown"
DURATION_SECS=0
SESSION_TIME_FILE="$HOME/.claude/.session-times/$SESSION_ID.start"
if [ -n "$SESSION_ID" ] && [ -f "$SESSION_TIME_FILE" ]; then
  START_TIME=$(cat "$SESSION_TIME_FILE")
  END_TIME=$(date +%s)
  DURATION_SECS=$((END_TIME - START_TIME))
  DURATION="${DURATION_SECS}s"
fi

if [[ -n "$TOOL_NAME" ]]; then
  echo "[$TIMESTAMP] Stop: $REASON (tool: $TOOL_NAME, duration: $DURATION)" >> "$LOG_FILE"
else
  echo "[$TIMESTAMP] Stop: $REASON (duration: $DURATION)" >> "$LOG_FILE"
fi

_TS=$((_SG_NOW_S - _SG_SESSION_START_S))
_REASON_SAFE="${REASON//\"/\\\"}"
printf '{"timestamp":%d,"event_type":"session_stop","tool":"Stop","session_id":"%s","reason":"%s","duration_seconds":%d}\n' \
  "$_TS" "$SESSION_ID" "$_REASON_SAFE" "${DURATION_SECS:-0}" \
  >> "$SG_EVENTS_FILE" 2>/dev/null

_BLOCK_COUNT=0
if [[ -f "$SG_EVENTS_FILE" ]]; then
  _BLOCK_COUNT=$(grep -c '"event_type":"blocked"' "$SG_EVENTS_FILE" || echo 0)
fi
jq -n \
  --arg s "Session: ${DURATION_SECS:-0}s | blocks: $_BLOCK_COUNT | reason: $REASON" \
  '{"stop_hook_summary": $s}'
