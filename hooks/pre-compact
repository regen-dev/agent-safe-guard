#!/usr/bin/env bash
# pre-compact: Inject session state before context compaction
set -euo pipefail

source "${BASH_SOURCE[0]%/*}/lib/common.sh"

_sg_read_input || exit 0

SESSION_ID=$(_sg_parse_session_id)
SESSION_ID=$(_sg_sanitize_id "$SESSION_ID")
[[ -z "$SESSION_ID" ]] && exit 0

# === GATHER SESSION STATE ===
STATE_FILE="$SG_STATE_DIR/session-$SESSION_ID"
SESSION_START_FILE="$HOME/.claude/.session-times/$SESSION_ID.start"

TOOL_COUNT=0
if [[ -f "$STATE_FILE" ]]; then
    IFS='|' read -r TOOL_COUNT _REST < "$STATE_FILE" 2>/dev/null
    [[ "$TOOL_COUNT" =~ ^[0-9]+$ ]] || TOOL_COUNT=0
fi

DURATION_MIN="unknown"
if [[ -f "$SESSION_START_FILE" ]]; then
    START_TIME=$(cat "$SESSION_START_FILE")
    NOW=$(date +%s)
    DURATION_SEC=$((NOW - START_TIME))
    DURATION_MIN=$((DURATION_SEC / 60))
fi

SUBAGENT_COUNT=0
SUBAGENT_COUNT_FILE="$SG_STATE_DIR/subagent-count"
if [[ -f "$SUBAGENT_COUNT_FILE" ]]; then
    IFS='|' read -r COUNT_SESSION COUNT _REST < "$SUBAGENT_COUNT_FILE" 2>/dev/null
    if [[ "$COUNT_SESSION" == "$SESSION_ID" && "$COUNT" =~ ^[0-9]+$ ]]; then
        SUBAGENT_COUNT="$COUNT"
    fi
fi

BUDGET_JSON=$(_sg_budget_export 2>/dev/null || echo '{}')
UTIL=$(echo "$BUDGET_JSON" | jq -r '.utilization // 0' | cut -d. -f1)
CONSUMED=$(echo "$BUDGET_JSON" | jq -r '.consumed // 0')
TOTAL=$(echo "$BUDGET_JSON" | jq -r '.total_limit // 0')
BUDGET_STATUS="${UTIL}% (${CONSUMED}/${TOTAL})"

# BUG FIX: Use jq -n for JSON construction instead of heredoc with newlines
SUMMARY="[SafeGuard Session State] Tool calls: $TOOL_COUNT | Duration: ${DURATION_MIN}m | Active subagents: $SUBAGENT_COUNT | Budget: $BUDGET_STATUS"

_TS=$((_SG_NOW_S - _SG_SESSION_START_S))
printf '{"timestamp":%d,"event_type":"compaction","tool":"PreCompact","session_id":"%s","tool_count":%d}\n' \
    "$_TS" "$SESSION_ID" "$TOOL_COUNT" \
    >> "$SG_EVENTS_FILE" 2>/dev/null

jq -n --arg ctx "$SUMMARY" \
    '{"hookSpecificOutput": {"hookEventName": "PreCompact", "additionalContext": $ctx}}'

exit 0
