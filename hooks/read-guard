#!/usr/bin/env bash
# Read guard: Block reads on large/bundled files
set -euo pipefail

source "${BASH_SOURCE[0]%/*}/lib/common.sh"

MAX_SIZE_MB=${SG_READ_GUARD_MAX_MB:-2}
MAX_SIZE_BYTES=$((MAX_SIZE_MB * 1024 * 1024))

_sg_read_input || exit 0

IFS=$'\t' read -r FILE_PATH < <(_sg_parse_tool_input file_path)

if [[ -z "$FILE_PATH" ]]; then
    exit 0
fi

BUNDLED_PATTERN_RE='(node_modules/|/dist/|/build/|\.min\.js$|\.bundle\.js$|expo-downloads/|\.chunk\.js$|/vendor/|/__generated__/|package-lock\.json$|yarn\.lock$|pnpm-lock\.yaml$|Cargo\.lock$|poetry\.lock$|composer\.lock$|Gemfile\.lock$|go\.sum$)'

if [[ "$FILE_PATH" =~ $BUNDLED_PATTERN_RE ]]; then
    SG_TOOL_NAME="Read" SG_COMMAND="$FILE_PATH" _sg_emit_block "read_bundled" 8000
    echo "Blocked: '$FILE_PATH' is a bundled/generated file; find the source" >&2
    exit 2
fi

if [[ -f "$FILE_PATH" ]]; then
    FILE_SIZE=$(stat -c%s "$FILE_PATH" 2>/dev/null || echo "0")
    if [[ "$FILE_SIZE" -gt "$MAX_SIZE_BYTES" ]]; then
        SIZE_MB=$(awk "BEGIN { printf \"%.1f\", $FILE_SIZE / 1024 / 1024 }" 2>/dev/null || echo "?")
        SG_TOOL_NAME="Read" SG_COMMAND="$FILE_PATH" _sg_emit_block "read_oversize" 25000
        echo "Blocked: '$FILE_PATH' is ${SIZE_MB}MB (max ${MAX_SIZE_MB}MB)" >&2
        exit 2
    fi
fi

exit 0
