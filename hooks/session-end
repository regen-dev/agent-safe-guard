#!/usr/bin/env bash
# session-end: Cleanup and session tracking
set -euo pipefail

source "${BASH_SOURCE[0]%/*}/lib/common.sh"

LOG_FILE="$HOME/.claude/session-log.txt"
RESET_REASON_FILE="$SG_STATE_DIR/reset-reason"

_sg_read_input || exit 0

IFS=$'\t' read -r SESSION_ID REASON < <(
    printf '%s' "$SG_INPUT" | jq -r '[.session_id // "unknown", .reason // ""] | @tsv' 2>/dev/null
) || exit 0
SESSION_ID=$(_sg_sanitize_id "$SESSION_ID")
[[ -z "$SESSION_ID" ]] && SESSION_ID="unknown"

SESSION_START_FILE="$HOME/.claude/.session-times/$SESSION_ID.start"
if [ -f "$SESSION_START_FILE" ]; then
  START_EPOCH=$(cat "$SESSION_START_FILE")
  END_EPOCH=$(date +%s)
  DURATION=$((END_EPOCH - START_EPOCH))
  DURATION_MIN=$((DURATION / 60))

  _TS=$((_SG_NOW_S - _SG_SESSION_START_S))
  printf '{"timestamp":%d,"event_type":"session_end","tool":"SessionEnd","session_id":"%s","duration_seconds":%d}\n' \
    "$_TS" "$SESSION_ID" "$DURATION" \
    >> "$SG_EVENTS_FILE" 2>/dev/null

  # Track budget delta
  START_BUDGET_FILE="$SG_SESSION_BUDGET_DIR/$SESSION_ID.start.json"
  if [ -f "$START_BUDGET_FILE" ]; then
    rm -f "$START_BUDGET_FILE"
  fi
else
  DURATION="unknown"
  DURATION_MIN="unknown"
fi

END_TIME=$(date '+%Y-%m-%d %H:%M:%S')

# Ghost subagent reaper: clean orphaned subagent state from THIS session
if [[ -d "$SG_SUBAGENT_STATE_DIR" ]]; then
    for state_file in "$SG_SUBAGENT_STATE_DIR"/*; do
        [ -f "$state_file" ] && [ ! -L "$state_file" ] || continue
        [[ "$(basename "$state_file")" == *.* ]] && continue
        grep -q "^SESSION_ID=${SESSION_ID}$" "$state_file" 2>/dev/null || continue
        rm -f "$state_file" "$state_file.start"
    done
fi

# Purge stale state files >24h
if [[ -d "$SG_STATE_DIR" ]]; then
    find "$SG_STATE_DIR" -maxdepth 1 -type f -name 'tool-count-*' -mtime +0 -exec rm -f {} + 2>/dev/null || true
    find "$SG_STATE_DIR" -maxdepth 1 -type f -name 'session-*' -mtime +0 -exec rm -f {} + 2>/dev/null || true
fi
if [[ -d "$SG_SUBAGENT_STATE_DIR" ]]; then
    find "$SG_SUBAGENT_STATE_DIR" -maxdepth 1 -type f -name '*.start' -mtime +0 -exec rm -f {} + 2>/dev/null || true
    find "$SG_SUBAGENT_STATE_DIR" -maxdepth 1 -type f ! -name '.*' -mtime +0 -exec rm -f {} + 2>/dev/null || true
fi

echo "[$END_TIME] Session ended: $SESSION_ID (duration: ${DURATION_MIN}m, dir: $PWD, reason: $REASON)" >> "$LOG_FILE"

if [ -n "$REASON" ]; then
    mkdir -p "$SG_STATE_DIR"
    printf '%s|%s|%s\n' "$(date +%s)" "$REASON" "$SESSION_ID" > "$RESET_REASON_FILE"
fi

exit 0
