#!/usr/bin/env bash
# session-start: Initialize session tracking
set -euo pipefail

source "${BASH_SOURCE[0]%/*}/lib/common.sh"

_sg_read_input || exit 0

SESSION_ID=$(_sg_parse_session_id)
SESSION_ID=$(_sg_sanitize_id "$SESSION_ID")

if [ -n "$SESSION_ID" ]; then
  mkdir -p "$HOME/.claude/.session-times"
  mkdir -p "$SG_SESSION_BUDGET_DIR"
  date +%s > "$HOME/.claude/.session-times/$SESSION_ID.start"
  _sg_date_sns > "$HOME/.claude/.session-times/$SESSION_ID.start_ns"
  mkdir -p "$SG_STATE_DIR"
  _sg_date_sns > "$SG_STATE_DIR/.session_start"

  _sg_budget_export > "$SG_SESSION_BUDGET_DIR/$SESSION_ID.start.json" 2>/dev/null || true

  # BUG FIX: escape $PWD for JSON via jq
  _CWD_JSON=$(jq -n --arg cwd "$PWD" '$cwd' 2>/dev/null)
  SESSION_LABEL="$(basename "$PWD") (${SESSION_ID: -6})"
  _LABEL_JSON=$(jq -n --arg label "$SESSION_LABEL" '$label' 2>/dev/null)
  printf '{"timestamp":0,"event_type":"session_start","tool":"SessionStart","session_id":"%s","cwd":%s,"session_label":%s}\n' \
    "$SESSION_ID" "$_CWD_JSON" "$_LABEL_JSON" \
    >> "$SG_EVENTS_FILE" 2>/dev/null
fi

exit 0
