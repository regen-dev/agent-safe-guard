#!/usr/bin/env bash
# Pre-tool-use: Token dump prevention, command safety, subagent enforcement
set -o pipefail

source "${BASH_SOURCE[0]%/*}/lib/common.sh"

_sg_read_input || exit 0

TOOL_NAME=$(_sg_parse_tool_name)
TRANSCRIPT_PATH=$(_sg_parse_transcript_path)
SESSION_ID=$(_sg_parse_session_id)
IFS=$'\t' read -r COMMAND < <(_sg_parse_tool_input command)

export SG_TOOL_NAME="$TOOL_NAME"
export SG_COMMAND="$COMMAND"
export SG_SESSION_ID="$SESSION_ID"

_sg_record_tool_start "$TOOL_NAME"

# === SUBAGENT DETECTION ===
IS_SUBAGENT=false
AGENT_TYPE=""
AGENT_ID=""

if _sg_is_subagent "$TRANSCRIPT_PATH"; then
    IS_SUBAGENT=true
    AGENT_ID=$(_sg_get_agent_id "$TRANSCRIPT_PATH")
    if [[ -n "$AGENT_ID" ]]; then
        AGENT_TYPE=$(_sg_get_agent_type "$AGENT_ID")
    fi
fi

# === SUBAGENT BUDGET ENFORCEMENT ===
if [[ "$IS_SUBAGENT" == true && -n "$AGENT_ID" ]]; then
    CALL_BUDGET=$(_sg_call_limit "$AGENT_TYPE")
    BYTE_BUDGET=$(_sg_byte_limit "$AGENT_TYPE")
    WARN_CALL_AT=$((CALL_BUDGET * 80 / 100))
    WARN_BYTE_AT=$((BYTE_BUDGET * 80 / 100))

    mkdir -p "$SG_SUBAGENT_STATE_DIR"
    CALL_FILE="$SG_SUBAGENT_STATE_DIR/$AGENT_ID.calls"
    BYTE_FILE="$SG_SUBAGENT_STATE_DIR/$AGENT_ID.bytes"

    CURRENT_CALLS=0
    if [[ -f "$CALL_FILE" ]]; then
        RAW=$(cat "$CALL_FILE" 2>/dev/null || echo "0")
        if [[ "$RAW" == *"|"* ]]; then
            CURRENT_CALLS=$(echo "$RAW" | cut -d'|' -f2)
        else
            CURRENT_CALLS="$RAW"
        fi
        [[ ! "$CURRENT_CALLS" =~ ^[0-9]+$ ]] && CURRENT_CALLS=0
    fi
    NEW_CALLS=$((CURRENT_CALLS + 1))
    printf '%s|%s|%s\n' "$AGENT_ID" "$NEW_CALLS" "$(date +%s)" > "$CALL_FILE"

    CURRENT_BYTES=0
    if [[ -f "$BYTE_FILE" ]]; then
        RAW=$(cat "$BYTE_FILE" 2>/dev/null || echo "0")
        if [[ "$RAW" == *"|"* ]]; then
            CURRENT_BYTES=$(echo "$RAW" | cut -d'|' -f1)
        else
            CURRENT_BYTES="$RAW"
        fi
        [[ ! "$CURRENT_BYTES" =~ ^[0-9]+$ ]] && CURRENT_BYTES=0
    fi

    if (( NEW_CALLS >= CALL_BUDGET )); then
        _sg_emit_block "budget_calls_exceeded" 2000
        _sg_deny "Budget exceeded: $AGENT_TYPE calls $NEW_CALLS/$CALL_BUDGET. Stop and report findings."
    elif (( NEW_CALLS >= WARN_CALL_AT )); then
        echo "WARNING: Tool call #$NEW_CALLS/$CALL_BUDGET for $AGENT_TYPE agent." >&2
    fi

    if (( CURRENT_BYTES >= BYTE_BUDGET )); then
        _sg_emit_block "budget_bytes_exceeded" $((CURRENT_BYTES / 4))
        _sg_deny "Budget exceeded: $AGENT_TYPE output ${CURRENT_BYTES}B/${BYTE_BUDGET}B. Stop and report findings."
    elif (( CURRENT_BYTES >= WARN_BYTE_AT )); then
        echo "WARNING: ${CURRENT_BYTES}B/$((BYTE_BUDGET/1024))KB cumulative output for $AGENT_TYPE agent." >&2
    fi
fi

# === NON-BASH TOOLS: fast path ===
case "$TOOL_NAME" in
    Write)
        CONTENT=$(printf '%s' "$SG_INPUT" | jq -r '.tool_input.content // ""' 2>/dev/null)
        FILE_PATH=$(printf '%s' "$SG_INPUT" | jq -r '.tool_input.file_path // ""' 2>/dev/null)
        (( ${#CONTENT} > SG_WRITE_MAX_BYTES )) && { _sg_emit_block "write_oversize" 25000 "Write ${#CONTENT}B -> $FILE_PATH"; _sg_deny "Write >${#CONTENT}B (>$((SG_WRITE_MAX_BYTES/1024))KB)"; }
        _sg_suppress_ok ;;
    Edit)
        NEW=$(printf '%s' "$SG_INPUT" | jq -r '.tool_input.new_string // ""' 2>/dev/null)
        FILE_PATH=$(printf '%s' "$SG_INPUT" | jq -r '.tool_input.file_path // ""' 2>/dev/null)
        (( ${#NEW} > SG_EDIT_MAX_BYTES )) && { _sg_emit_block "edit_oversize" 12500 "Edit ${#NEW}B -> $FILE_PATH"; _sg_deny "Edit >${#NEW}B (>$((SG_EDIT_MAX_BYTES/1024))KB)"; }
        _sg_suppress_ok ;;
    NotebookEdit)
        NEW_SOURCE=$(printf '%s' "$SG_INPUT" | jq -r '.tool_input.new_source // ""' 2>/dev/null)
        (( ${#NEW_SOURCE} > SG_NOTEBOOK_MAX_BYTES )) && { _sg_emit_block "notebook_oversize" 12500 "NotebookEdit ${#NEW_SOURCE}B"; _sg_deny "NotebookEdit >${#NEW_SOURCE}B (>$((SG_NOTEBOOK_MAX_BYTES/1024))KB)"; }
        _sg_suppress_ok ;;
    Glob)
        read -r PATTERN GLOB_PATH < <(printf '%s' "$SG_INPUT" | jq -r '[.tool_input.pattern // "", .tool_input.path // ""] | @tsv' 2>/dev/null)
        HOME_DIR_RE='^(/home/[^/]+|~|/Users/[^/]+|/root)/?$'
        if [[ "$PATTERN" =~ \*\* ]]; then
            if [[ "$GLOB_PATH" =~ $HOME_DIR_RE ]] || [[ -z "$GLOB_PATH" && "$PWD" =~ $HOME_DIR_RE ]]; then
                _sg_emit_block "glob_home_recursive" 5000 "Glob $PATTERN in $GLOB_PATH"; _sg_deny "Glob ** in home dir; narrow path or use fd"
            fi
            if [[ "$PATTERN" =~ ^(/home/[^/]+|~|/Users/[^/]+|/root)/\*\* ]]; then
                _sg_emit_block "glob_home_recursive" 5000 "Glob $PATTERN"; _sg_deny "Glob ** in home dir; narrow path or use fd"
            fi
        fi
        _sg_suppress_ok ;;
    Bash) ;;
    *) _sg_suppress_ok ;;
esac

[[ -z "$COMMAND" ]] && _sg_suppress_ok

# ==========================================================================
# BASH TOOL CHECKS
# ==========================================================================

# === CRITICAL DENY RULES ===
NORM_CMD=$(echo "$COMMAND" | tr -s '[:space:]' ' ')
case "$NORM_CMD" in
    *"rm -rf /"*|*"rm -fr /"*|*"rm -rf ~"*|*"rm -fr ~"*|\
    *"rm -rf ."*|*"rm -fr ."*|*"rm -rf *"*|*"rm -fr *"*|\
    *"rm --recursive --force"*|*"rm --force --recursive"*|\
    *"rm -rf --no-preserve-root"*|\
    *"mkfs"*|*"dd if="*|*"dd of=/dev/"*|\
    *"> /dev/sd"*|*"> /dev/nvme"*|\
    *"chmod -R 777 /"*|*"chown -R"*|*"chown --recursive"*)
        _sg_emit_block "destructive_cmd" 0; _sg_deny "Blocked destructive command" ;;
esac

# Fork bomb detection
if [[ "$NORM_CMD" =~ :\(\)[[:space:]]*\{[[:space:]]*:\|:[[:space:]]*\&[[:space:]]*\} ]]; then
    _sg_emit_block "fork_bomb" 0; _sg_deny "Blocked fork bomb"
fi

# RCE detection: curl/wget piped to interpreters (BUG FIX: added && and redirect+execute)
case "$NORM_CMD" in
    *"curl"*"|"*"bash"*|*"curl"*"|"*"sh"*|*"curl"*"|"*"zsh"*|\
    *"curl"*"|"*"python"*|*"curl"*"|"*"perl"*|*"curl"*"|"*"ruby"*|*"curl"*"|"*"node"*|\
    *"wget"*"|"*"bash"*|*"wget"*"|"*"sh"*|*"wget"*"|"*"zsh"*|\
    *"wget"*"|"*"python"*|*"wget"*"|"*"perl"*|*"wget"*"|"*"ruby"*|*"wget"*"|"*"node"*|\
    *"bash <(curl"*|*"sh <(curl"*|*"zsh <(curl"*|\
    *"bash <(wget"*|*"sh <(wget"*|*"zsh <(wget"*|\
    *"python"*" <(curl"*|*"python"*" <(wget"*|\
    *"curl"*"&&"*"bash"*|*"curl"*"&&"*"sh"*|\
    *"wget"*"&&"*"bash"*|*"wget"*"&&"*"sh"*|\
    *"curl"*">"*"&&"*"bash"*|*"curl"*">"*"&&"*"sh"*|\
    *"wget"*">"*"&&"*"bash"*|*"wget"*">"*"&&"*"sh"*|\
    *"curl"*">"*"; bash"*|*"curl"*">"*"; sh"*|\
    *"wget"*">"*"; bash"*|*"wget"*">"*"; sh"*)
        _sg_emit_block "rce_pipe" 0; _sg_deny "Blocked remote code execution" ;;
esac

# === SUBAGENT BASH-SPECIFIC BLOCKS ===
if [[ "$IS_SUBAGENT" == true ]]; then
    [[ "$COMMAND" =~ (^|[[:space:]]|[;&|])[[:space:]]*find[[:space:]] ]] && { _sg_emit_block "subagent_find" 3000; _sg_deny "Use Glob tool instead of find"; }
    [[ "$COMMAND" =~ xargs[[:space:]]+(grep|rg) ]] && { _sg_emit_block "subagent_xargs_grep" 5000; _sg_deny "Use Grep tool instead of xargs grep"; }
    [[ "$COMMAND" =~ (^|[;&]|&&|\|\|)[[:space:]]*grep[[:space:]] ]] && { _sg_emit_block "subagent_grep" 5000; _sg_deny "Use Grep tool or rg instead of grep"; }
    [[ "$COMMAND" =~ ^[[:space:]]*ls[[:space:]].*(-la|-al|-lah|-lha) ]] && { _sg_emit_block "subagent_ls_verbose" 2000; _sg_deny "Use tree -L 2 or Glob tool instead of ls -la"; }
    [[ "$COMMAND" =~ ^[[:space:]]*cat[[:space:]].*\* ]] && { _sg_emit_block "subagent_cat_glob" 10000; _sg_deny "Use Glob then Read for pattern-matched files"; }
    if [[ "$COMMAND" =~ ^[[:space:]]*cat[[:space:]].*[[:space:]] ]] && [[ ! "$COMMAND" =~ \| ]]; then
        ARGS=$(echo "$COMMAND" | sed 's/^[[:space:]]*cat[[:space:]]*//' | tr ' ' '\n' | rg -v '^-' | awk 'END{print NR}')
        (( ARGS > 2 )) && { _sg_emit_block "subagent_cat_multi" 5000; _sg_deny "Use Read tool for multiple files (parallel)"; }
    fi
fi

# === FFMPEG CHECK ===
if [[ "$COMMAND" =~ ffmpeg ]] && [[ ! "$COMMAND" =~ -nostats ]]; then
    _sg_emit_block "ffmpeg_verbose" 5000; _sg_deny "ffmpeg commands must include -nostats -loglevel error"
fi

# === FORCE OVERRIDE ===
[[ "$COMMAND" =~ '#'[[:space:]]*'FORCE_READ' ]] && _sg_suppress_ok

# === BUILD ARTIFACTS CHECK ===
BUILD_ARTIFACT='(\.vite/build|/dist/[^/]+\.(js|css)|\.min\.(js|css)|bundle\.(js|css))'
IS_BUILD_ARTIFACT=false
[[ "$COMMAND" =~ $BUILD_ARTIFACT ]] && IS_BUILD_ARTIFACT=true

# === QUICK ALLOW: metadata commands ===
[[ "$COMMAND" =~ ^[[:space:]]*(wc|stat|file|du|md5sum|sha256sum|sha1sum|cksum)[[:space:]] ]] && _sg_suppress_ok

# === QUICK ALLOW: piped output (NOT for build artifacts) ===
if [[ "$IS_BUILD_ARTIFACT" == false ]] && [[ "$COMMAND" =~ \|[[:space:]]*(head|tail|wc|grep|awk|sed)[[:space:]] ]]; then
    _sg_suppress_ok
fi

# === GIT COMMIT ===
if [[ "$COMMAND" =~ git[[:space:]]+commit ]] && [[ ! "$COMMAND" =~ (-q|--quiet) ]]; then
    _sg_emit_block "git_commit_verbose" 3000; _sg_deny "Use git commit -q"
fi

# === GIT LOG (unbounded) ===
if [[ "$COMMAND" =~ ^[[:space:]]*git[[:space:]]+log ]] && [[ ! "$COMMAND" =~ (-n[[:space:]]*[0-9]+|-[0-9]+|--oneline|--format|--pretty|--since|--after|\|[[:space:]]*(head|tail)) ]]; then
    _sg_emit_block "git_log_unbounded" 10000; _sg_deny "git log needs -n, --oneline, or pipe"
fi

# === VERBOSE COMMANDS ===
if [[ "$COMMAND" =~ ^npm[[:space:]]+(install|i|ci)([[:space:]]|$) ]] && [[ ! "$COMMAND" =~ (--silent|--quiet|\||'>'|'&') ]]; then
    _sg_emit_block "npm_verbose" 5000; _sg_deny "npm install/ci needs --silent or pipe"
fi
if [[ "$COMMAND" =~ ^cargo[[:space:]]+build ]] && [[ ! "$COMMAND" =~ (-q|--quiet|\||'>'|'&') ]]; then
    _sg_emit_block "cargo_verbose" 5000; _sg_deny "cargo build needs -q or pipe"
fi
if [[ "$COMMAND" =~ ^make([[:space:]]|$) ]] && [[ ! "$COMMAND" =~ (-s|--silent|\||'>'|'&') ]]; then
    _sg_emit_block "make_verbose" 5000; _sg_deny "make needs -s or pipe"
fi
if [[ "$COMMAND" =~ ^pip[[:space:]]+(install|download) ]] && [[ ! "$COMMAND" =~ (-q|--quiet) ]]; then
    _sg_emit_block "pip_verbose" 3000; _sg_deny "pip needs -q"
fi
if [[ "$COMMAND" =~ ^curl[[:space:]] ]]; then
    if [[ "$COMMAND" =~ (-v|--verbose) ]] && [[ ! "$COMMAND" =~ (\||>>?|-o|-O|--output|--remote-name) ]]; then
        _sg_emit_block "curl_verbose" 2000; _sg_deny "curl -v needs output redirection"
    fi
fi
if [[ "$COMMAND" =~ ^wget[[:space:]] ]] && [[ ! "$COMMAND" =~ (-q|--quiet|-O) ]]; then
    _sg_emit_block "wget_verbose" 2000; _sg_deny "wget needs -q"
fi
if [[ "$COMMAND" =~ ^docker[[:space:]]+(build|pull) ]] && [[ ! "$COMMAND" =~ (-q|--quiet|\|) ]]; then
    _sg_emit_block "docker_verbose" 8000; _sg_deny "docker build/pull needs -q or pipe"
fi

# === BUILD ARTIFACTS (minified files) ===
if [[ "$IS_BUILD_ARTIFACT" == true ]]; then
    if [[ "$COMMAND" =~ grep ]] && [[ ! "$COMMAND" =~ (head[[:space:]]+-c.*\|[[:space:]]*grep|-l[[:space:]]|--files-with-matches|\|[[:space:]]*(wc|head|tail)) ]]; then
        _sg_emit_block "grep_minified" 25000; _sg_deny "grep on minified file; use Grep tool or pipe head -c first"
    fi
    if [[ "$COMMAND" =~ (cat|head|tail)[[:space:]].*$BUILD_ARTIFACT ]] && [[ ! "$COMMAND" =~ (-c[[:space:]]*[0-9]+) ]]; then
        _sg_emit_block "cat_minified" 25000; _sg_deny "Minified file; use head -c 4000"
    fi
fi

# === RECURSIVE GREP (main agent only) ===
if [[ "$IS_SUBAGENT" == false ]]; then
    if [[ "$COMMAND" =~ grep.*([[:space:]]-[a-zA-Z]*[rR][a-zA-Z]*|--recursive) ]] && [[ ! "$COMMAND" =~ (-l[[:space:]]|--files-with-matches) ]]; then
        [[ ! "$COMMAND" =~ \|[[:space:]]*(head|tail|wc) ]] && {
            _sg_emit_block "grep_recursive" 10000; _sg_deny "grep -r scans all - use rg or grep -l"
        }
    fi
fi

# === RECURSIVE FIND ===
for pat in '\.claude' '\.git' 'node_modules'; do
    if [[ "$COMMAND" =~ find.*$pat ]] && [[ ! "$COMMAND" =~ (-maxdepth[[:space:]]+[1-3]|\|[[:space:]]*(head|tail|wc)|-name[[:space:]]) ]]; then
        _sg_emit_block "find_recursive" 5000; _sg_deny "find in $pat needs -maxdepth or pipe"
    fi
done

# === BOUNDED HEAD/TAIL ===
if [[ "$COMMAND" =~ ^[[:space:]]*(head|tail) ]]; then
    if [[ "$COMMAND" =~ -n[[:space:]]*([0-9]+) ]] || [[ "$COMMAND" =~ -([0-9]+) ]] || [[ "$COMMAND" =~ --lines=([0-9]+) ]]; then
        limit="${BASH_REMATCH[1]}"
        (( limit <= 500 )) && _sg_suppress_ok
    fi
fi

# === LARGE FILE CHECK ===
[[ "$COMMAND" =~ -c[[:space:]]*[0-9]+ ]] && _sg_suppress_ok

if [[ "$COMMAND" =~ ^[[:space:]]*(cat|head|tail|less|more|bat|batcat)[[:space:]]+ ]]; then
    REST="${COMMAND#*"${BASH_REMATCH[0]}"}"
    set -f
    for arg in $REST; do
        case "$arg" in '|'|'&&'|';'|'||'|'>'|'>>'|'<'|'&') break ;; esac
        [[ "$arg" =~ ^- ]] && continue
        expanded="${arg/#\~/$HOME}"
        if [[ -f "$expanded" ]]; then
            filetype=$(file -b "$expanded" 2>/dev/null | head -c 50)
            if [[ "$filetype" =~ ^(ELF|PE32|Mach-O|data|image|audio|video|gzip|Zip|PDF|SQLite|compiled) ]]; then
                _sg_emit_block "binary_file" 10000; _sg_deny "$expanded is binary ($filetype). Use file, xxd, or hexdump"
            fi
            size=$(stat -c%s "$expanded" 2>/dev/null || echo 0)
            if (( size > 1048576 )); then
                _sg_emit_block "large_file" $((size/4)); _sg_deny "$expanded is $((size/1024))KB (>1MB). Use head -c 4000"
            fi
        fi
    done
    set +f
fi

_sg_suppress_ok
