# claude-safe-guard: configurable thresholds
# Source: ~/.claude/.safeguard/config.env

# Truncation thresholds
SG_TRUNCATE_BYTES=20480          # 20KB generic output truncation
SG_SUBAGENT_READ_BYTES=10240     # 10KB subagent Read truncation
SG_SUPPRESS_BYTES=524288         # 500KB suppress entirely
SG_READ_GUARD_MAX_MB=2           # Max file size for Read tool

# Write/Edit size limits
SG_WRITE_MAX_BYTES=102400        # 100KB max Write content
SG_EDIT_MAX_BYTES=51200          # 50KB max Edit new_string
SG_NOTEBOOK_MAX_BYTES=51200      # 50KB max NotebookEdit

# Subagent budgets
SG_DEFAULT_CALL_LIMIT=30         # Default tool calls per subagent
SG_DEFAULT_BYTE_LIMIT=102400     # Default cumulative output bytes per subagent

# Session budget (estimated tokens)
SG_BUDGET_TOTAL=280000

# Repomap (ranked repo tag map injected into SessionStart additionalContext).
# SG_REPOMAP_MAX_TOKENS is a chars/4 approximation; 4096 fits 3-4 files on
# typical TS/JS repos. 1024 starves real repos (see docs/repomap.md).
SG_REPOMAP_MAX_TOKENS=4096
SG_REPOMAP_MAX_FILE_BYTES=524288   # Skip source files bigger than 512 KB
SG_REPOMAP_MAX_TAGS_PER_FILE=40    # Cap per-file contribution (0 = unlimited)
